{
	// See https://go.microsoft.com/fwlink/?LinkId=733558
	// for the documentation about the tasks.json format
	"version": "2.0.0",
	"tasks": [
		{
			"label": "generate vulkanbox",
			"type": "shell",
			"command": "mingen -c ${input:generate_config} --compile-db",
			"problemMatcher": [],
			"linux": {
				"command": "./mingen -c ${input:generate_config} --compile-db"
			},
			"osx": {
				"command": "./mingen -c ${input:generate_config} --compile-db"
			}
		},
		{
			"label": "build",
			"type": "shell",
			"command": "ninja -C build",
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			},
			"group": "build",
			"problemMatcher": [
				{
					"owner": "gcc",
					"fileLocation": [
						"autoDetect",
						"${workspaceFolder}"
					],
					"source": "gcc",
					"pattern": [
						{
							"regexp": "^(.*?):(\\d+):(\\d*):?\\s+(?:fatal\\s+)?(warning|error):\\s+(.*)$",
							"file": 1,
							"line": 2,
							"column": 3,
							"severity": 4,
							"message": 5
						}
					]
				}
			]
		},
		{
			"label": "build slangrc",
			"type": "shell",
			"command": "ninja -C build bin/slangrc",
			"windows": {
				"command": "ninja -C build bin/slangrc.exe"
			},
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			},
			"group": "build",
			"problemMatcher": [
				"$gcc",
				"$msCompile"
			]
		}
	],
	"inputs": [
		{
			"id": "generate_config",
			"description": "Generation Configuration",
			"type": "pickString",
			"options": [
				"debug",
				"release"
			],
			"default": "debug"
		}
	]
}